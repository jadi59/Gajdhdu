<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ADMIN KEY PANEL</title>

<style>
body{
margin:0;
font-family:sans-serif;
background:#0d0d12;
color:#fff;
display:flex;
justify-content:center;
padding:20px;
}

.panel{
width:100%;
max-width:800px;
}

.box{
background:#1a1a22;
padding:20px;
border-radius:15px;
margin-bottom:15px;
border:1px solid #333;
}

input,button{
padding:10px;
border-radius:10px;
border:none;
margin:5px;
}

input{
width:120px;
}

button{
cursor:pointer;
background:#ff8c00;
color:#fff;
font-weight:bold;
}

.key-item{
display:flex;
justify-content:space-between;
align-items:center;
padding:10px;
background:#111;
margin-top:10px;
border-radius:10px;
border:1px solid #222;
}

.badge{
padding:3px 8px;
border-radius:8px;
font-size:12px;
}

.red{background:red;}
.green{background:green;}
</style>
</head>

<body>

<div class="panel">

<h2>📊 ADMIN PANEL</h2>

<!-- CREATE -->
<div class="box">
<h3>สร้างคีย์</h3>

<input id="prefix" placeholder="PREFIX (VIP)">
<input id="amount" placeholder="จำนวน" type="number">
<input id="days" placeholder="วันหมดอายุ" type="number">

<button onclick="createKeys()">สร้าง</button>
</div>

<!-- SEARCH -->
<div class="box">
<h3>ค้นหาคีย์</h3>
<input id="search" placeholder="ใส่คีย์">
<button onclick="searchKey()">ค้นหา</button>
</div>

<!-- RESULT -->
<div class="box">
<h3>RESULT</h3>
<div id="result"></div>
</div>

</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import {
getFirestore,
doc,
setDoc,
getDoc
} from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

/* 🔥 ใส่ Firebase ของคุณ */
const firebaseConfig = {
apiKey: "AIzaSyBdSsDIgiB2RvqC0udxgp8YNyBFDsksDUw",
  authDomain: "reczssa.firebaseapp.com",
  projectId: "reczssa",
  storageBucket: "reczssa.firebasestorage.app",
  messagingSenderId: "726475292690",
  appId: "1:726475292690:web:12d844b3b605ad650cd8cb"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

/* =========================
   CREATE MULTI KEYS
========================= */
window.createKeys = async function(){

const prefix = document.getElementById("prefix").value || "VIP";
const amount = parseInt(document.getElementById("amount").value || 1);
const days = parseInt(document.getElementById("days").value || 1);

let output = "";

for(let i=0;i<amount;i++){

const key = prefix + "-" + Math.random().toString(36).substring(2,8).toUpperCase();

await setDoc(doc(db,"keys",key),{
createdAt: Date.now(),
expire: Date.now() + (days*86400000),
banned:false,
device:null
});

output += key + "\n";
}

alert("สร้างคีย์เสร็จ");

document.getElementById("result").innerText = output;

};

/* =========================
   SEARCH KEY
========================= */
window.searchKey = async function(){

const key = document.getElementById("search").value.trim();
const result = document.getElementById("result");

if(!key) return;

const ref = doc(db,"keys",key);
const snap = await getDoc(ref);

if(!snap.exists()){
result.innerHTML = "❌ ไม่พบคีย์";
return;
}

const data = snap.data();

result.innerHTML = `
<div class="key-item">
<div>
<b>${key}</b><br>
<small>expire: ${new Date(data.expire).toLocaleString()}</small><br>
<span class="badge ${data.banned ? 'red':'green'}">
${data.banned ? 'BANNED':'ACTIVE'}
</span>
</div>

<div>
<button onclick="copyKey('${key}')">COPY</button>
<button onclick="banKey('${key}')">BAN</button>
<button onclick="unbanKey('${key}')">UNBAN</button>
</div>
</div>
`;

};

/* =========================
   COPY KEY
========================= */
window.copyKey = function(key){
navigator.clipboard.writeText(key);
alert("COPIED: " + key);
};

/* =========================
   BAN / UNBAN
========================= */
window.banKey = async function(key){
await setDoc(doc(db,"keys",key),{banned:true},{merge:true});
alert("BANNED");
searchKey();
};

window.unbanKey = async function(key){
await setDoc(doc(db,"keys",key),{banned:false},{merge:true});
alert("UNBANNED");
searchKey();
};

</script>

</body>
</html>
